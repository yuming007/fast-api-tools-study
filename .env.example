APP_NAME=fast-api-tools-study
LOG_LEVEL=INFO

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=study
MYSQL_PASSWORD=study
MYSQL_DB=crawler
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20
MYSQL_POOL_RECYCLE_SECONDS=1800
MYSQL_POOL_TIMEOUT_SECONDS=30

REDIS_URL=redis://redis:6379/0
REDIS_CELERY_RESULT_BACKEND_URL=redis://redis:6379/1
REDIS_NAMESPACE=study

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=study
RABBITMQ_PASSWORD=study
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=study.tasks
RABBITMQ_QUEUE=crawl.jobs
RABBITMQ_ROUTING_KEY=crawl.execute
RABBITMQ_SCHEDULER_QUEUE=scheduler.jobs
RABBITMQ_SCHEDULER_ROUTING_KEY=scheduler.scan

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=study
CLICKHOUSE_PASSWORD=study
CLICKHOUSE_DB=crawler_analytics

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=articles

MOCK_SOURCE_BASE_URL=http://mock-source:8004

SEARCH_CACHE_TTL_SECONDS=90
SEARCH_CACHE_REBUILD_LOCK_SECONDS=8
SEARCH_CACHE_WAIT_TIMEOUT_MS=250
ARTICLE_DEDUPE_TTL_SECONDS=600
SCHEDULER_POLL_SECONDS=15
REQUEST_TIMEOUT_SECONDS=15
MANUAL_DISPATCH_THROTTLE_SECONDS=5
CELERY_TASK_TIME_LIMIT_SECONDS=180
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=120
CELERY_RESULT_EXPIRES_SECONDS=3600
CELERY_WORKER_CONCURRENCY=4
